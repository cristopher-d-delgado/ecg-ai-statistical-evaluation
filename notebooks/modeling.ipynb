    "class PerClassTemperatureScaling(nn.Module):\n",
    "    \"\"\"\n",
    "    Per-class temperature scaling for multi-label calibration.\n",
    "    Learns one scalar temperature T per class independently.\n",
    "\n",
    "    Args:\n",
    "        n_classes (int): Number of output classes.\n",
    "        init_temp (float): Initial temperature for all classes. Default 1.0.\n",
    "    \"\"\"\n",
    "\n",
    "    def __init__(self, n_classes: int = 5, init_temp: float = 1.0):\n",
    "        super().__init__()\n",
    "        # One independent leaf Parameter per class\n",
    "        self.temps = nn.ParameterList([\n",
    "            nn.Parameter(torch.tensor([init_temp]))\n",
    "            for _ in range(n_classes)\n",
    "        ])\n",
    "\n",
    "    def forward(self, logits: torch.Tensor) -> torch.Tensor:\n",
    "        \"\"\"\n",
    "        Scale each class logit by its own temperature.\n",
    "\n",
    "        Args:\n",
    "            logits (torch.Tensor): Raw logits of shape (N, n_classes).\n",
    "\n",
    "        Returns:\n",
    "            torch.Tensor: Scaled logits of shape (N, n_classes).\n",
    "        \"\"\"\n",
    "        scaled = torch.stack([\n",
    "            logits[:, i] / self.temps[i]\n",
    "            for i in range(len(self.temps))\n",
    "        ], dim=1)\n",
    "        return scaled\n",
    "\n",
    "    def calibrate(self, val_loader, model, criterion, device,\n",
    "                  lr: float = 0.01, max_iter: int = 100) -> np.ndarray:\n",
    "        \"\"\"\n",
    "        Fit one temperature per class on validation set independently.\n",
    "\n",
    "        Args:\n",
    "            val_loader: Validation DataLoader.\n",
    "            model: Trained ResNet1D model.\n",
    "            criterion: Loss function.\n",
    "            device: Compute device.\n",
    "            lr (float): LBFGS learning rate. Default 0.01.\n",
    "            max_iter (int): Max iterations per class. Default 100.\n",
    "\n",
    "        Returns:\n",
    "            np.ndarray: Optimal temperature per class of shape (n_classes,).\n",
    "        \"\"\"\n",
    "        self.to(device)\n",
    "\n",
    "        # Collect all validation logits once — model weights frozen\n",
    "        model.eval()\n",
    "        all_logits = []\n",
    "        all_labels = []\n",
    "\n",
    "        with torch.no_grad():\n",
    "            for signals, labels in val_loader:\n",
    "                signals = signals.to(device)\n",
    "                logits  = model(signals)\n",
    "                all_logits.append(logits.cpu())\n",
    "                all_labels.append(labels.cpu())\n",
    "\n",
    "        all_logits = torch.cat(all_logits).to(device)\n",
    "        all_labels = torch.cat(all_labels).to(device)\n",
    "\n",
    "        optimal_temps = []\n",
    "\n",
    "        for i in range(len(self.temps)):\n",
    "            # Reset this class temperature to 1.0\n",
    "            self.temps[i].data.fill_(1.0)\n",
    "\n",
    "            # Each temp[i] is a leaf Parameter — LBFGS can optimize it\n",
    "            optimizer = optim.LBFGS(\n",
    "                [self.temps[i]],\n",
    "                lr       = lr,\n",
    "                max_iter = max_iter\n",
    "            )\n",
    "\n",
    "            def eval_loss(idx=i):\n",
    "                optimizer.zero_grad()\n",
    "                scaled_logit = all_logits[:, idx] / self.temps[idx]\n",
    "                loss         = nn.BCEWithLogitsLoss()(\n",
    "                    scaled_logit, all_labels[:, idx]\n",
    "                )\n",
    "                loss.backward()\n",
    "                return loss\n",
    "\n",
    "            optimizer.step(eval_loss)\n",
    "\n",
    "            # Clamp to reasonable range\n",
    "            self.temps[i].data.clamp_(0.1, 10.0)\n",
    "            optimal_temps.append(round(float(self.temps[i].item()), 4))\n",
    "\n",
    "        return np.array(optimal_temps)"
   ]
