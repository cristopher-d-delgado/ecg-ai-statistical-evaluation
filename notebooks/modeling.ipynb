    "from sklearn.metrics import roc_auc_score\n",
    "import pandas as pd\n",
    "\n",
    "# Load all test probabilities\n",
    "lr_test_probs     = np.load(ARTIFACTS / 'log_test_probs.npy')\n",
    "rf_test_probs     = np.load(ARTIFACTS / 'rf_test_probs.npy')\n",
